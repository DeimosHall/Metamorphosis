<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>@app-id@</id>

    <name>Metamorphosis</name>
    <developer id="io.dev.deimoshall">
        <name translate="no">Deimos Hall</name>
    </developer>
    <summary>Edit EXIF metadata</summary>

    <metadata_license>CC-BY-SA-4.0</metadata_license>
    <project_license>GPL-3.0-only</project_license>

    <description>
        <p>
            Convert between different image filetypes and resize them easily.
        </p>
    </description>

    <translation type="gettext">@gettext-package@</translation>

    <requires>
        <display_length compare="ge">360</display_length>
        <internet>offline-only</internet>
    </requires>

    <recommends>
        <control>pointing</control>
        <control>keyboard</control>
        <control>touch</control>
    </recommends>

    <branding>
        <color type="primary" scheme_preference="light">#f18e57</color>
        <color type="primary" scheme_preference="dark">#980e8c</color>
    </branding>

    <screenshots>
        <screenshot type="default">
            <image>
                https://github.com/DeimosHall/Metamorphosis/-/raw/main/data/resources/screenshots/0.png</image>
            <caption>Converting sample image from PNG to HEIF</caption>
        </screenshot>
        <screenshot>
            <image>
                https://github.com/DeimosHall/Metamorphosis/-/raw/main/data/resources/screenshots/1.png</image>
            <caption>Converting multiple sample images from SVG to HEIF</caption>
        </screenshot>
    </screenshots>

    <launchable type="desktop-id">@app-id@.desktop</launchable>

    <url type="homepage">https://apps.gnome.org/Metamorphosis/</url>
    <url type="donation">https://opencollective.com/metamorphosis</url>
    <url type="bugtracker">https://github.com/DeimosHall/Metamorphosis/issues</url>
    <url type="help">https://github.com/DeimosHall/Metamorphosis/issues</url>
    <url type="vcs-browser">https://github.com/DeimosHall/Metamorphosis</url>
    <url type="translate">https://github.com/DeimosHall/Metamorphosis/tree/main/po</url>
    <url type="contribute">https://github.com/DeimosHall/Metamorphosis</url>
    <url type="contact">https://matrix.to/#/@deimos:gnome.org</url>

    <update_contact>deimos@deimoshall.io</update_contact>

    <content_rating type="oars-1.1" />

</component>